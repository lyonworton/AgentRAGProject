# Docker deployment environment
# Paths are container-internal (/app/models/) since models are mounted

DATABASE_URL=postgresql+asyncpg://agentrag:agentrag@postgres:5432/agentrag
MILVUS_HOST=milvus
MILVUS_PORT=19530
REDIS_URL=redis://redis:6379/0
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=agentrag123
ES_HOST=http://elasticsearch:9200

LLM_PROVIDER=openai
OPENAI_API_KEY=sk-1df9b3bd61a94e58816b3081842f846a
OPENAI_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash
EMBEDDING_MODEL=text-embedding-3-small
BGE_EMBEDDING_MODEL=/app/models/BAAI/bge-m3
EMBEDDING_DIM=1024
USE_GPU=false

SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

APP_ENV=production
LOG_LEVEL=INFO
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=100

RERANKER_PROVIDER=rrf
RERANKER_MODEL=/app/models/BAAI/bge-reranker-v2-m3
RERANKER_TOP_K=20
RRF_K=60

# Xinference (GPU embedding)
EMBEDDING_BACKEND=xinference
XINFERENCE_ENDPOINT=http://xinference:9997
XINFERENCE_EMBEDDING_MODEL=bge-m3
