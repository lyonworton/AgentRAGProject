# ============================================================
# AgentRAG — Environment Variables Template
# Copy this file to .env and customize for your environment.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://agentrag:agentrag@localhost:5432/agentrag

# --- Milvus (Vector Store) ---
MILVUS_HOST=localhost
MILVUS_PORT=19530

# --- Redis (Job Queue) ---
REDIS_URL=redis://localhost:6379/0

# --- Neo4j (Knowledge Graph) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=agentrag123

# --- Elasticsearch (Full-text Search) ---
ES_HOST=http://localhost:9200

# --- LLM (OpenAI-compatible API) ---
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash

# --- Embedding ---
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1024

# --- Xinference (GPU Embedding Server) ---
XINFERENCE_ENDPOINT=http://127.0.0.1:9997
XINFERENCE_EMBEDDING_MODEL=bge-m3

# --- Reranker ---
RERANKER_PROVIDER=rrf
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# RERANKER_TOP_K=20
# RRF_K=60

# --- Auth ---
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=100
